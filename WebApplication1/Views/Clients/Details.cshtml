@model WebApplication1.DTOs.ClientReponseDto

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Client</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>

        @* AJUSTE AQUI: Lógica para exibir a lista de perfis *@
        <dt class="col-sm-2">
            Perfis de Acesso
        </dt>
        <dd class="col-sm-10">
            @if (Model.Profiles != null && Model.Profiles.Any())
            {
                foreach (var perfil in Model.Profiles)
                {
                    <span class="badge bg-info text-dark me-1">@perfil</span>
                }
            }
            else
            {
                <span class="text-muted">Nenhum perfil atribuído</span>
            }
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ativo)
        </dt>
        <dd class="col-sm-10">
            @(Model.Ativo ? "Sim" : "Não")
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edit</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>